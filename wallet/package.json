{
  "name": "pivx-wallet",
  "version": "0.4.0",
  "description": "Standalone PIVX wallet SDK: local key management, shielded (SHIELD/Sapling) scanning, balances, and transaction building. The node is only a chain-data source.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Liquid369/pivx-js-sdk.git",
    "directory": "wallet"
  },
  "homepage": "https://github.com/Liquid369/pivx-js-sdk#readme",
  "bugs": "https://github.com/Liquid369/pivx-js-sdk/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "keywords": [
    "pivx",
    "wallet",
    "sapling",
    "shield",
    "sdk",
    "payments"
  ],
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/base": "^2.2.0",
    "@scure/bip32": "^2.2.0",
    "pivx-rpc": "^0.6.0",
    "pivx-shield-rust": "^1.4.0"
  },
  "optionalDependencies": {
    "pivx-shield-rust-multicore": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.5.0"
  }
}
