{
  "name": "pivx-rpc",
  "version": "0.4.0",
  "description": "PIVX SDK: typed JSON-RPC client with shielded (SHIELD/Sapling) balance watching and transaction support",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Liquid369/pivx-js-sdk.git",
    "directory": "rpc"
  },
  "homepage": "https://github.com/Liquid369/pivx-js-sdk#readme",
  "bugs": "https://github.com/Liquid369/pivx-js-sdk/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "keywords": [
    "pivx",
    "rpc",
    "sapling",
    "shield",
    "blockchain",
    "cryptocurrency"
  ],
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.5.0"
  }
}
