{
  "name": "pivx-rpc",
  "version": "0.1.0",
  "description": "PIVX SDK: typed JSON-RPC client with shielded (SHIELD/Sapling) balance watching and transaction support",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "keywords": [
    "pivx",
    "rpc",
    "sapling",
    "shield",
    "blockchain",
    "cryptocurrency"
  ],
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.5.0"
  }
}
